# Copy to .env and fill in real values. .env is gitignored; this file is not.
#
# All three are read server-side only, inside pages/api/*. They are deliberately
# NOT prefixed NEXT_PUBLIC_ — that would inline them into the browser bundle and
# publish them. See CLAUDE.md.

# https://open-platform.theguardian.com/access/
GUARDIAN_API_KEY=

# https://developer.nytimes.com/get-started
NYT_API_KEY=

# https://newsapi.org/register
NEWSAPI_KEY=
