# Copy to .env and fill in real values. .env is gitignored; this file is not.
#
# All keys are read server-side only, inside pages/api/* and getServerSideProps.
# They are deliberately NOT prefixed NEXT_PUBLIC_ — that would inline them into
# the browser bundle and publish them. This repo is public. See CLAUDE.md.

# https://open-platform.theguardian.com/access/
GUARDIAN_API_KEY=

# https://developer.nytimes.com/get-started
# The Article Search API authenticates with this key alone. NYT also issues a
# secret, but it is only for their OAuth-style apps — this endpoint does not take
# it, so NYT_SECRET_API_KEY is not read anywhere. Setting it is harmless; it is
# simply unused.
NYT_API_KEY=

# https://newsapi.org/register
# The free tier is dev-only and rejects browser-origin requests — which is fine,
# because every call is made server-side anyway.
NEWSAPI_KEY=

# Offline mode. Set to 1 to serve the recorded fixtures in
# lib/sources/__fixtures__ instead of calling the providers, so the whole app —
# SSR, the API route, the feed — runs with no keys at all, or when a free-tier
# rate limit is spent. Leave unset to hit the real APIs.
NEWS_FIXTURES=
